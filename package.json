{
  "name": "wa-gateway",
  "version": "2.0.0",
  "description": "WhatsApp Gateway - Node.js + Express + WebSocket",
  "main": "server.js",
  "scripts": {
    "postinstall": "node scripts/download-chromium.js",
    "start": "node server.js",
    "start:frontend": "node frontend.js",
    "start:all": "concurrently \"node server.js\" \"node frontend.js\"",
    "dev": "nodemon server.js",
    "dev:frontend": "nodemon frontend.js",
    "dev:all": "concurrently \"nodemon server.js\" \"nodemon frontend.js\""
  },
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^3.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.2",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^9.0.0",
    "whatsapp-web.js": "^1.26.1-alpha.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.1.2",
    "nodemon": "^3.0.3",
    "tailwindcss": "^4.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
